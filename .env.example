# Control Plane target.
#
# Auth is handled by your local `cpln` CLI — run `cpln login` once on this
# machine. deploy.sh uses your default profile unless CPLN_PROFILE is set.
# The webapp workload itself receives CPLN_ORG, CPLN_GVC, and CPLN_TOKEN
# auto-injected at runtime (scoped to the webapp's identity) — not set here.

CPLN_ORG=your-org-name

# Optional — use a specific cpln profile instead of the default.
# Leave unset (or empty) to use whichever profile is marked default in `cpln profile get`.
# CPLN_PROFILE=my-profile
